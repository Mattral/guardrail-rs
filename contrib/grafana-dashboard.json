{
  "title": "guardrail-rs",
  "description": "Request decisions, blocks, redactions, and pipeline latency for guardrail-rs.",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["guardrail-rs", "llm-security"],
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Requests by decision",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (decision) (rate(guardrail_requests_total[5m]))",
          "legendFormat": "{{decision}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Blocked requests by code",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (code) (rate(guardrail_blocked_total[5m]))",
          "legendFormat": "{{code}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Request-side PII redactions / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(guardrail_redacted_total[5m])",
          "legendFormat": "request redactions/sec"
        }
      ]
    },
    {
      "id": 6,
      "title": "Response-side PII redactions / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "rate(guardrail_response_redacted_total[5m])",
          "legendFormat": "response redactions/sec"
        }
      ]
    },
    {
      "id": 7,
      "title": "Upstream errors by class",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "sum by (error_class) (rate(guardrail_upstream_errors_total[5m]))",
          "legendFormat": "{{error_class}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Pipeline latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(guardrail_pipeline_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(guardrail_pipeline_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(guardrail_pipeline_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 8,
      "title": "End-to-end request latency incl. upstream (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(guardrail_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(guardrail_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(guardrail_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 5,
      "title": "Per-stage latency (p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(guardrail_stage_duration_seconds_bucket[5m])) by (le, stage))",
          "legendFormat": "{{stage}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Active connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "guardrail_active_connections",
          "legendFormat": "connections"
        }
      ]
    }
  ]
}
